<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:include filename="$(find fishbot_description)/urdf/fishbot/common_inertial.xacro"/>

    <xacro:macro name="wheel_xacro" params="wheel_name xyz">
        <link name="${wheel_name}_link">
            <!-- 部件的外观描述 -->
            <visual>
            <!-- 沿着自己几何中心的偏移和旋转量 -->
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <!-- 形状描述 -->
                <geometry>
                    <cylinder radius="0.032" length="0.04"/>
                </geometry>
                <!-- 材质描述 -->
                <material name="yellow">
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </visual>
            <collision>
                <!-- 沿着自己几何中心的偏移和旋转量 -->
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <!-- 形状描述 -->
                <geometry>
                    <cylinder radius="0.032" length="0.04"/>
                </geometry>
                <!-- 材质描述 -->
                <material name="yellow">
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </collision>
            <xacro:cylinder_inertia m="0.05" r="0.032" h="0.04"/>

        </link>

        <joint name="${wheel_name}_joint" type="continuous">
            <origin xyz="${xyz}" rpy="0.0 0.0 0.0"/>
            <parent link="base_link"/>
            <child link="${wheel_name}_link"/>
            <axis xyz="0 1 0"/>
        </joint>

        <gazebo reference="${wheel_name}_link">
            <!-- 切向摩擦系数 -->
            <mu1 value="20.0"/> 
            <!-- 法向摩擦系数 -->
            <mu2 value="20.0"/>
            <!-- 刚度系数 -->
            <kp value="1000000000.0"/>
            <!-- 阻尼系数 -->
            <kd value="1.0"/>
        </gazebo>
    </xacro:macro>
</robot>